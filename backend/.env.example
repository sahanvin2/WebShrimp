# Server
PORT=3000
CORS_ORIGIN=http://localhost:8080

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/loopingon

# AI
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=x-ai/grok-4.1-fast
OPENROUTER_SITE_URL=http://localhost:8080
OPENROUTER_SITE_NAME=Loopingon

# Storage / CDN
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_ACCESS_KEY_ID=your_b2_access_key_id
B2_SECRET_ACCESS_KEY=your_b2_secret_access_key
B2_BUCKET=your_bucket_name
B2_REGION=us-east-005
B2_PUBLIC_BASE=https://your-cdn-domain.b-cdn.net
